networks:
  public:
    external: true

services:
  nginx:
    image: nginx:latest
    container_name: fdroid-nginx
    restart: unless-stopped
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - /home/admin/fdroid:/usr/share/nginx/html/fdroid:ro
    ports:
      - "8666:8666"
    networks:
      - public
